    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.GetIncidentRecord</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns the GLideRecord object representing the incident based on its number or Sys Id.</description>
        <mobile_callable>false</mobile_callable>
        <name>GetIncidentRecord</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function GetIncidentRecord(vIncident)
{
	grIncident = GetRecord('incident',vIncident);
	if (IsValidRecord(grIncident))
	{
		return grIncident;
	}
	var grIncident = new GlideRecord('incident');
	grIncident.addQuery('number','=',vIncident);
	grIncident.query();
	if (grIncident.getRowCount() == 1)
	{
		if (grIncident.next() == true)
		{
			return grIncident;
		}
	}
	return false;
}]]></script>
