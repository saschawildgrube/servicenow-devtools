    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.IsValidAppIdentifierString</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given string is either a Sys Id, a scope name or a valid application name, false if not.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsValidAppIdentifierString</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsValidAppIdentifierString(strIdentifier)
{
	if (GetType(strIdentifier) != 'string')
	{
		return false;
	}
	if (IsValidSysId(strIdentifier) == true)
	{
		return true;
	}
	if (IsValidName(strIdentifier) == true)
	{
		return true;
	}
	if (IsSnakeCase(strIdentifier) == true)
	{
		return true;
	}
	return false;
}]]></script>
