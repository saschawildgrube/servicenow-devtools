    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.GetPluginRecord</api_name>
        <caller_access>1</caller_access>
        <client_callable>false</client_callable>
        <description>Returns the requested sys_plugin record based on the "source" field (i.e. the technical name) or display name.</description>
        <mobile_callable>false</mobile_callable>
        <name>GetPluginRecord</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function GetPluginRecord(vPlugin)
{
	if (IsValidRecord(vPlugin) == true)
	{
		if (vPlugin.getRecordClassname() == 'sys_plugins')
		{
			return vPlugin; 
		}
		return false;
	}
	var strNeedle = GetStringValue(vPlugin);
	var grPlugin = new GlideRecord('sys_plugins');
	var condition = grPlugin.addQuery('source','=',strNeedle);
	condition.addOrCondition('name','=',strNeedle);
	grPlugin.query();
	if (grPlugin.getRowCount() != 1)
	{
		return false;
	}
	if (grPlugin.next() == false)
	{
		return false;
	}
	return grPlugin;
}]]></script>
