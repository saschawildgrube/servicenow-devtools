    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.WaitForInstanceScan</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Waits until an in-flight Instance Scan run is finished. The function does not wait longer than the given amount of seconds - 60 seconds by default.&#13;
The function returns if Instance Scan is running at the end of the waiting period. </description>
        <mobile_callable>false</mobile_callable>
        <name>WaitForInstanceScan</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function WaitForInstanceScan(nMaxSeconds)
{
	nMaxSeconds = GetIntegerValue(nMaxSeconds);
	if (nMaxSeconds == 0)
	{
		nMaxSeconds = 60;
	}
	var stopwatch = new StopWatch();
	stopwatch.Start();
	while (InstanceScanIsRunning() && stopwatch.GetSeconds() < nMaxSeconds)
	{
		Sleep(1);
	}
	return InstanceScanIsRunning();
}]]></script>
