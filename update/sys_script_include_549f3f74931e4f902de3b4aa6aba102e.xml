        <description>Returns true if the current script context is invoked as part of an ATF test, false if not.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsTestSession</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsTestSession()
{
	var aCallStack = GetCallStack();
	var top = GetValue(aCallStack,aCallStack.length - 1);
	var strClassName = GetStringValue(GetValue(top,'sys_class_name'));
	if (strClassName.indexOf('sys_atf_step') == 0)
	{
		return true;
	}
	return false;
}]]></script>
