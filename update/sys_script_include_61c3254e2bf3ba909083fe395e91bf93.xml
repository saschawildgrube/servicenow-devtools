        <api_name>x_snc_devtools.IsAgenticConversationIdleOrInactive</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given Agentic conversation is active and idle OR inactive OR non-existent.&#13;
Effectively, the function returns false if it's worth "waiting" for the agent to finish.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsAgenticConversationIdleOrInactive</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsAgenticConversationIdleOrInactive(vConversation)
{
	var grConversation = GetAgenticConversationRecord(vConversation);
	if (IsValidRecord(grConversation) == false)
	{
		return true;
	}

	if (IsAgenticConversationActive(grConversation) == false)
	{
		return true;
	}

	// check if there are any signs of work in progress

	return false;
}]]></script>
