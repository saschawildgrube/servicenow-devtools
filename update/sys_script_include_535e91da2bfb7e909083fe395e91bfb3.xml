    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.WaitForAgenticConversation</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Waits until an agentic conversation becomes idle or inactive.</description>
        <mobile_callable>false</mobile_callable>
        <name>WaitForAgenticConversation</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function WaitForAgenticConversation(vConversation)
{
	var grConversation = GetAgenticConversationRecord(vConversation);
	if (IsValidRecord(grConversation) == false)
	{
		return false;
	}
	while (IsAgenticConversationIdleOrInactive(grConversation.sys_id) == false)
	{
		Sleep(1);
	}
	return true;
}]]></script>
