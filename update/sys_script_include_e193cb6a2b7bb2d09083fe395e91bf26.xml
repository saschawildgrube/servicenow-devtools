    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.ArrayGetElementById</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns the element of an array based on a match on a given attribute ("id" by default).</description>
        <mobile_callable>false</mobile_callable>
        <name>ArrayGetElementById</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function ArrayGetElementById(aHaystack, strNeedle, strAttribute)
{
	aHaystack = GetArrayValue(aHaystack);
	if (aHaystack.length == 0)
	{
		return false;
	}

	strAttribute = GetStringValue(strAttribute);
	if (strAttribute == '')
	{
		strAttribute = 'id';
	}

	strNeedle = GetStringValue(strNeedle);
	if (strNeedle == '')
	{
		return false;
	}

	for (var nElement = 0; nElement < aHaystack.length; nElement++)
	{
		var element = aHaystack[nElement];
		if (IsObject(element) == true)
		{
			if (GetValue(element,strAttribute) == strNeedle)
			{
				return element;
			}
		}
	}

	return false;
}]]></script>
