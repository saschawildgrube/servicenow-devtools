        <api_name>x_snc_devtools.GetSandboxName</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns the sandbox name if the current instance is a sandbox, false if not.</description>
        <mobile_callable>false</mobile_callable>
        <name>GetSandboxName</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function GetSandboxName()
{
	var strSandboxName = RunScriptInGlobalScope(
		"result = false;"
		+"if (typeof sn_dsb != 'undefined')"
		+"{"
		+"   var dsbApi = new sn_dsb.API();"
		+"   if (dsbApi.isDsb())"
		+"   {"
		+"      result = dsbApi.getDsb();"
		+"   }"
		+"}");

	return strSandboxName;
}]]></script>
