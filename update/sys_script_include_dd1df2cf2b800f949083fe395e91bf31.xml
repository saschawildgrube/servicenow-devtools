        <api_name>x_snc_devtools.IsValidBoolString</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given value is a string representing a boolean value - e.g. "0", "1", "true" or "false".</description>
        <mobile_callable>false</mobile_callable>
        <name>IsValidBoolString</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsValidBoolString(vValue)
{
	if (GetType(vValue) != 'string')
	{
		return false;
	}
	var strValue = vValue.toLowerCase();
	var aPatterns = ['0','1','true','false','yes','no'];
	for (var nPattern = 0; nPattern < aPatterns.length; nPattern++)
	{
		if (strValue == aPatterns[nPattern])
		{
			return true;
		}
	}
	return false;
}]]></script>
