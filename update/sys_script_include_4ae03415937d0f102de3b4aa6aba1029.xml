    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.IsPrimeTierLicenseAvailable</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the instance has the AI Native Prime Tier License, false if not.&#13;
The Prime Tier is required to run custom AI agents.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsPrimeTierLicenseAvailable</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsPrimeTierLicenseAvailable()
{
	if (typeof sn_aia == 'undefined')
	{
		return false;
	}
	var util = new sn_aia.AIAgentLicensingUtil();
	var license = util.lookupLicensingTier();
	return GetBoolValue(GetValue(license,'hasPrimeTier')); 
}]]></script>
