    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.GroupAddUser</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Adds the given user to the given group.</description>
        <mobile_callable>false</mobile_callable>
        <name>GroupAddUser</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function GroupAddUser(vGroup,vUser)
{
	var grGroup = GetGroupRecord(vGroup);
	if (IsValidRecord(grGroup) == false)
	{
		return false;
	}
	var grUser = GetGroupRecord(vUser);
	if (IsValidRecord(grUser) == false)
	{
		return false;
	}

	var strSysId = RecordInserOrUpdate(
		'sys_user_grmember',
		{
			group: grGroup.sys_id,
			user: grUser.sys_id
		},
		{},
		{},
		true);
	return IsValidSysId(strSysId);
}]]></script>
