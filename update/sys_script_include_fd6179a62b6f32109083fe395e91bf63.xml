<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_script_include">
    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.GetRecentEvaluatorErrorsQuery</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns the encoded query to filter the syslog table for recent evaluator errors given a time frame in minutes.</description>
        <mobile_callable>false</mobile_callable>
        <name>GetRecentEvaluatorErrorsQuery</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function GetRecentEvaluatorErrorsQuery(nMinutes)
{
	nMinutes = GetIntegerValue(nMinutes);
	if (nMinutes == 0)
	{
		nMinutes = 5;
	}

	var strQuery = 'sys_created_onRELATIVEGT@minute@ago@'+nMinutes;
	strQuery += '^source=Evaluator';
	
	var aPatterns = GetEvaluatorErrorExceptionPatterns();
	for (var nPattern = 0; nPattern < aPatterns.length; nPattern++)
	{
		strQuery += '^messageNOT LIKE' + aPatterns[nPattern];
	}
	strQuery += '^ORDERBYDESCsys_created_on';

	return strQuery;
}]]></script>
        <sys_class_name>sys_script_include</sys_class_name>
