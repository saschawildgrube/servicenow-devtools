        <api_name>x_snc_devtools.IsValidJson</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given parameter is a string and is a valid JSON string, false if not.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsValidJson</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsValidJson(strJson)
{
	if (GetType(strJson) != 'string' && GetType(strJson) != 'String')
	{
		return false;
	}
	var json = ParseJson(strJson);
	if (IsObject(json) == false)
	{
		return false;
	}
	return true;
}]]></script>
