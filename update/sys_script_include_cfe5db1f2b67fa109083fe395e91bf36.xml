    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.IsUiActionVisibleBaselineSharedApp</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the UI Action "Baseline Shared App" should be visible.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsUiActionVisibleBaselineSharedApp</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsUiActionVisibleBaselineSharedApp(grApp)
{
	if (IsActive() == false)
	{
		return false;
	}

	if (GetAppCurrentBranch(grApp) == '')
	{
		return false;
	}

	if (AppGetProperty('ui.baseline_button') == false)
	{
		return false;
	}

	var grSharedApp = GetSharedApplicationRecord(grApp)

	if (IsValidRecord(grSharedApp) == false)
	{
		return false;
	}

	if (grSharedApp.baseline_support == false)
	{
		return false;
	}

	return true;
}]]></script>
