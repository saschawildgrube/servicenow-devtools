        <api_name>x_snc_devtools.IsNowAssistAIAgentsInstalled</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true of the AI Agent and Agentic Workflow capability is available on the instance., false if not.</description>
        <mobile_callable>false</mobile_callable>
        <name>IsNowAssistAIAgentsInstalled</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsNowAssistAIAgentsInstalled()
{
	if (GlidePluginManager.isActive('sn_genai_platform') == false)
	{
		return false;
	}
	if (GlidePluginManager.isActive('sn_aia') == false)
	{
		return false;
	}
	if (IsValidTable('sn_aia_agent') == false)
	{
		return false;
	}
	return true;
}]]></script>
