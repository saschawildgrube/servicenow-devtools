        <api_name>x_snc_devtools.IsSecureParameterValue</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given string does not contain any traces of SQL, syntax or code injection patterns. </description>
        <mobile_callable>false</mobile_callable>
        <name>IsSecureParameterValue</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsSecureParameterValue(strValue)
{
	strValue = GetStringValue(strValue);

	var aPatterns = [
		'"',
		"'",
		'<',
		'>',
		'- -'
		];


	for (var nPattern = 0; nPattern < aPatterns.length; nPattern++)
	{
		if (strValue.indexOf(aPatterns[nPattern]) != -1)
		{
			return false;
		}
	}
	return true;
}]]></script>
