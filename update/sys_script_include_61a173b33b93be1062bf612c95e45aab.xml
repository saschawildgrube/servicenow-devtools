    <sys_script_include action="INSERT_OR_UPDATE">
        <access>public</access>
        <active>true</active>
        <api_name>x_snc_devtools.IsAgenticConversationActive</api_name>
        <caller_access/>
        <client_callable>false</client_callable>
        <description>Returns true if the given agentic conversation is active, false if not.&#13;
If the given agentic conversation cannot be identified, the function also returns false. </description>
        <mobile_callable>false</mobile_callable>
        <name>IsAgenticConversationActive</name>
        <sandbox_callable>false</sandbox_callable>
        <script><![CDATA[function IsAgenticConversationActive(vConversation)
{
	var grConversation = GetAgenticConversationRecord(vConversation);
	if (IsValidRecord(grConversation) == false)
	{
		return false;
	}

	if (grConversation.state == 'open')
	{
		return true;
	}

	return false;
}]]></script>
